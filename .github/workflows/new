name: Cross Compile Android IR Keytable

on:
  workflow_dispatch:

jobs:
  build:
    runs-on: ubuntu-latest

    steps:
    - name: Checkout repository
      uses: actions/checkout@v3

    - name: Set up environment variables
      run: |
        wget https://github.com/gjasny/v4l-utils/archive/refs/heads/master.zip
        unzip -o master.zip -d .
        #mv v4l-utils-master/utils/keytable/
        

    - name: Cache Android NDK
      id: cache-ndk
      uses: actions/cache@v3
      with:
        path: android-ndk-r25b
        key: android-ndk-r25b-linux

    - name: Download and setup Android NDK
      if: steps.cache-ndk.outputs.cache-hit != 'true'
      run: |
        wget https://dl.google.com/android/repository/android-ndk-r25b-linux.zip
        unzip android-ndk-r25b-linux.zip
        echo "ANDROID_NDK_ROOT=${PWD}/android-ndk-r25b" >> $GITHUB_ENV

    - name: Set up Android NDK toolchain
      run: |
        export ANDROID_NDK_ROOT=${PWD}/android-ndk-r25b
        TOOLCHAIN=$ANDROID_NDK_ROOT/toolchains/llvm/prebuilt/linux-x86_64
        echo "$TOOLCHAIN/bin" >> $GITHUB_PATH
        echo "ANDROID_NDK_ROOT=${ANDROID_NDK_ROOT}" >> $GITHUB_ENV

    - name: Install dependencies
      run: |
        sudo apt-get update
        sudo apt-get install -y build-essential bc bison flex libncurses5-dev unzip wget

    - name: Compile IR Keytable
      run: |
        # Set up Android NDK toolchain
        export ANDROID_NDK_ROOT=${PWD}/android-ndk-r25b
        TOOLCHAIN=$ANDROID_NDK_ROOT/toolchains/llvm/prebuilt/linux-x86_64
        
        # ARM64 compilation for Android TV 11 (API 30)
        export AR=$TOOLCHAIN/bin/llvm-ar
        export CC=$TOOLCHAIN/bin/aarch64-linux-android30-clang
        export CXX=$TOOLCHAIN/bin/aarch64-linux-android30-clang++
        export LD=$TOOLCHAIN/bin/ld
        export STRIP=$TOOLCHAIN/bin/llvm-strip
        
        # Show compiler version and target
        echo "Compiler version:"
        ${CC} --version

        cd v4l-utils-master/utils/keytable/
        # Compile for ARM64 (Android TV 11 - API 30)
        echo "Compiling ir-keytable for ARM64 (Android TV 11 - API 30)..."
        ${CC} \
          -target aarch64-linux-android30 \
          -fPIE \
          -fPIC \
          -DANDROID \
          -D__ANDROID__ \
          -D_GNU_SOURCE \
          -D_POSIX_C_SOURCE=200809L \
          -DANDROID_CONFIG_H \
          -I. \
          -o ir-keytable-arm64 \
          ir-encode.c keymap.c keytable.c toml.c bpf_load.c \
          -lm -lz
        
        # Check if compilation was successful
        if [ $? -ne 0 ]; then
          echo "ARM64 Compilation failed!"
          exit 1
        fi
        
        # Compile for ARM (Android TV 11 - API 30)
        echo "Compiling ir-keytable for ARM (Android TV 11 - API 30)..."
        export CC=$TOOLCHAIN/bin/armv7a-linux-androideabi30-clang
        export CXX=$TOOLCHAIN/bin/armv7a-linux-androideabi30-clang++
        
        ${CC} \
          -target armv7a-linux-androideabi30 \
          -fPIE \
          -fPIC \
          -DANDROID \
          -D__ANDROID__ \
          -D_GNU_SOURCE \
          -D_POSIX_C_SOURCE=200809L \
          -DANDROID_CONFIG_H \
          -I. \
          -o ir-keytable-arm \
          ir-encode.c keymap.c keytable.c toml.c bpf_load.c \
          -lm -lz
        
        # Check if compilation was successful
        if [ $? -ne 0 ]; then
          echo "ARM Compilation failed!"
          exit 1
        fi
        
        # Verify the binaries
        echo "Verifying the compiled ARM64 binary..."
        file ir-keytable-arm64
        ls -la ir-keytable-arm64
        echo "Checking ELF headers for ARM64:"
        readelf -h ir-keytable-arm64 | grep -E "Class|Machine|Type" || echo "Unable to read ELF headers"
        
        echo "Verifying the compiled ARM binary..."
        file ir-keytable-arm
        ls -la ir-keytable-arm
        echo "Checking ELF headers for ARM:"
        readelf -h ir-keytable-arm | grep -E "Class|Machine|Type" || echo "Unable to read ELF headers"
        
        # Strip debug symbols
        ${STRIP} ir-keytable-arm64
        ${STRIP} ir-keytable-arm
        echo "Binaries after stripping:"
        ls -la ir-keytable-arm64 ir-keytable-arm
        mv ir-keytable-arm64 ir-keytable-arm ../../../

    - name: Upload compiled binary
      uses: actions/upload-artifact@v4
      with:
        name: ir-keytable-binary
        path: |
          ir-keytable-arm64
          ir-keytable-arm
